FREESCOUT_URL=https://your-freescout-instance.com
FREESCOUT_EMAIL=your-email@example.com
FREESCOUT_PASSWORD=your-password-here

# Optional settings
HEADLESS_MODE=false
BROWSER_WAIT_TIME=10
# Speed: 1.0=normal, 0.5=faster, 0.4=fast (reduces fixed waits; lower may be flaky)
BROWSER_DELAY_SCALE=1.0

# Optional: primary email column if not "Email" (e.g. bounced-list export)
# EXCEL_EMAIL_COLUMN=Alternate Emails

# Optional: only if FILTER_BY_OUTREACH=true in config.py
# OUTREACH_FILTER_VALUE=Your Name As In Sheet
